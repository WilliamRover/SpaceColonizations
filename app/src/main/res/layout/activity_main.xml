<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Including the ship stat layouts directly instead of using a RecyclerView -->

    <TextView
        android:id="@+id/textView2"
        android:layout_width="88dp"
        android:layout_height="19dp"
        android:layout_marginStart="40dp"
        android:layout_marginTop="52dp"
        android:text="Hull Strength: "
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="89dp"
        android:layout_height="34dp"
        android:layout_marginStart="152dp"
        android:layout_marginTop="12dp"
        android:text="Ship level 1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textView3"
        android:layout_width="0dp"
        android:layout_height="19dp"
        android:layout_marginStart="76dp"
        android:layout_marginTop="1dp"
        android:text="Energy: "
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView2" />

    <TextView
        android:id="@+id/textView7"
        android:layout_width="88dp"
        android:layout_height="19dp"
        android:layout_marginStart="628dp"
        android:layout_marginTop="48dp"
        android:text="Hull Strength: "
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textView6"
        android:layout_width="72dp"
        android:layout_height="19dp"
        android:layout_marginStart="716dp"
        android:layout_marginTop="20dp"
        android:text="Enemy ship"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/enemyShipModel"
        android:layout_width="281dp"
        android:layout_height="143dp"
        android:layout_marginTop="132dp"
        android:layout_marginEnd="656dp"
        android:rotation="180"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/enemyshipplacebo" />

    <ImageView
        android:id="@+id/friendlyShipModel"
        android:layout_width="443dp"
        android:layout_height="181dp"
        android:layout_marginStart="320dp"
        android:layout_marginTop="100dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/friendlyship" />

    <TextView
        android:id="@+id/friendlyExplode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="184dp"
        android:layout_marginEnd="348dp"
        android:alpha="0"
        android:text="BOOM"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/enemyExplode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="76dp"
        android:layout_marginBottom="196dp"
        android:alpha="0"
        android:text="BOOM"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/friendlyShipHp"
        android:layout_width="145dp"
        android:layout_height="12dp"
        android:layout_marginStart="2dp"
        android:layout_marginTop="8dp"
        android:progress="100"
        app:indicatorColor="#62BA5F"
        app:indicatorTrackGapSize="0dp"
        app:layout_constraintStart_toEndOf="@+id/textView2"
        app:layout_constraintTop_toBottomOf="@+id/textView"
        app:trackColor="#DFDFDF"
        app:trackCornerRadius="0dp"
        app:trackStopIndicatorSize="0dp"
        app:trackThickness="12dp" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/enemyShipHp"
        android:layout_width="145dp"
        android:layout_height="12dp"
        android:layout_marginTop="15dp"
        android:progress="100"
        app:indicatorColor="#62BA5F"
        app:indicatorTrackGapSize="0dp"
        app:layout_constraintStart_toEndOf="@+id/textView7"
        app:layout_constraintTop_toBottomOf="@+id/textView6"
        app:trackColor="#DFDFDF"
        app:trackCornerRadius="0dp"
        app:trackStopIndicatorSize="0dp"
        app:trackThickness="12dp" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/friendlyShipEnergy"
        android:layout_width="145dp"
        android:layout_height="12dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="10dp"
        android:progress="100"
        app:indicatorColor="#5787FF"
        app:indicatorTrackGapSize="0dp"
        app:layout_constraintStart_toEndOf="@+id/textView3"
        app:layout_constraintTop_toBottomOf="@+id/friendlyShipHp"
        app:trackColor="#DFDFDF"
        app:trackCornerRadius="0dp"
        app:trackStopIndicatorSize="0dp"
        app:trackThickness="12dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
