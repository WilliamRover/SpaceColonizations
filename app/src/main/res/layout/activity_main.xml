<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Including the ship stat layouts directly instead of using a RecyclerView -->

    <TextView
        android:id="@+id/textView2"
        android:layout_width="88dp"
        android:layout_height="19dp"
        android:layout_marginStart="40dp"
        android:layout_marginTop="52dp"
        android:text="Hull Strength: "
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="89dp"
        android:layout_height="34dp"
        android:layout_marginStart="152dp"
        android:layout_marginTop="12dp"
        android:text="Ship level 1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/friendlyShipEnergy"
        android:layout_width="117dp"
        android:layout_height="19dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="1dp"
        android:text="friendlyShipEnergy"
        app:layout_constraintStart_toEndOf="@+id/textView3"
        app:layout_constraintTop_toBottomOf="@+id/friendlyShipHP" />

    <TextView
        android:id="@+id/textView3"
        android:layout_width="0dp"
        android:layout_height="19dp"
        android:layout_marginStart="80dp"
        android:layout_marginTop="1dp"
        android:text="Energy: "
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView2" />

    <TextView
        android:id="@+id/friendlyShipHP"
        android:layout_width="93dp"
        android:layout_height="19dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:text="friendlyShipHP"
        app:layout_constraintStart_toEndOf="@+id/textView2"
        app:layout_constraintTop_toBottomOf="@+id/textView" />

    <TextView
        android:id="@+id/textView7"
        android:layout_width="88dp"
        android:layout_height="19dp"
        android:layout_marginStart="664dp"
        android:layout_marginTop="48dp"
        android:text="Hull Strength: "
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textView6"
        android:layout_width="72dp"
        android:layout_height="19dp"
        android:layout_marginStart="716dp"
        android:layout_marginTop="20dp"
        android:text="Enemy ship"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/enemyShipHP"
        android:layout_width="88dp"
        android:layout_height="19dp"
        android:layout_marginStart="3dp"
        android:layout_marginTop="28dp"
        android:text="enemyShipHP"
        app:layout_constraintStart_toEndOf="@+id/textView7"
        app:layout_constraintTop_toTopOf="@+id/textView6" />

    <ImageView
        android:id="@+id/enemyShipModel"
        android:layout_width="281dp"
        android:layout_height="143dp"
        android:layout_marginTop="132dp"
        android:layout_marginEnd="656dp"
        android:rotation="180"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/enemyshipplacebo" />

    <ImageView
        android:id="@+id/friendlyShipModel"
        android:layout_width="443dp"
        android:layout_height="181dp"
        android:layout_marginStart="320dp"
        android:layout_marginTop="100dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/friendlyship" />

    <TextView
        android:id="@+id/friendlyExplode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="184dp"
        android:layout_marginEnd="348dp"
        android:alpha="0"
        android:text="BOOM"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/enemyExplode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="76dp"
        android:layout_marginBottom="196dp"
        android:alpha="0"
        android:text="BOOM"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>