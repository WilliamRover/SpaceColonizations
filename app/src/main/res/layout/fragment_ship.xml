<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/friendlyShipModel"
        android:layout_width="540dp"
        android:layout_height="205dp"
        android:layout_marginStart="332dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ship_model_friendly_v2" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/shipHpBar"
        android:layout_width="145dp"
        android:layout_height="12dp"
        android:layout_marginTop="12dp"
        android:progress="100"
        app:indicatorColor="#4C904C"
        app:indicatorTrackGapSize="0dp"
        app:layout_constraintEnd_toEndOf="@+id/textView"
        app:layout_constraintStart_toStartOf="@+id/textView"
        app:layout_constraintTop_toBottomOf="@+id/textView"
        app:trackColor="#DFDFDF"
        app:trackCornerRadius="0dp"
        app:trackStopIndicatorSize="0dp"
        app:trackThickness="16dp" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:text="The Great Ship"
        android:textColor="#FBFBFB"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.47"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/hullStrengthSymbol"
        android:layout_width="15dp"
        android:layout_height="14dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="10dp"
        app:layout_constraintEnd_toStartOf="@+id/shipHpBar"
        app:layout_constraintTop_toBottomOf="@+id/textView"
        app:srcCompat="@drawable/hullstrength" />

    <TextView
        android:id="@+id/friendlyHpTxt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="52dp"
        android:text="num/100"
        android:textColor="#3F663B"
        android:textSize="10sp"
        app:layout_constraintBottom_toBottomOf="@+id/shipHpBar"
        app:layout_constraintStart_toStartOf="@+id/shipHpBar" />

    <!-- Station Buttons -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/trainingCenterBtn"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="280dp"
        android:layout_marginTop="4dp"
        android:alpha="0.3"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text=""
        app:layout_constraintStart_toStartOf="@+id/friendlyShipModel"
        app:layout_constraintTop_toTopOf="@+id/friendlyShipModel"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Circle"
        app:strokeColor="#979797"
        app:strokeWidth="6dp" />

    <TextView
        android:id="@+id/trainingCenterBtnLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Training center"
        android:textColor="#82AED2"
        android:textSize="10sp"
        app:layout_constraintBottom_toBottomOf="@+id/trainingCenterBtn"
        app:layout_constraintEnd_toEndOf="@+id/trainingCenterBtn"
        app:layout_constraintStart_toStartOf="@+id/trainingCenterBtn"
        app:layout_constraintTop_toTopOf="@+id/trainingCenterBtn" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/commandBtn"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="312dp"
        android:layout_marginTop="84dp"
        android:alpha="0.3"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text=""
        app:layout_constraintStart_toStartOf="@+id/friendlyShipModel"
        app:layout_constraintTop_toTopOf="@+id/friendlyShipModel"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Circle"
        app:strokeColor="#979797"
        app:strokeWidth="6dp" />

    <TextView
        android:id="@+id/commandBtnLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Command"
        android:textColor="#82AED2FF"
        android:textSize="10sp"
        app:layout_constraintBottom_toBottomOf="@+id/commandBtn"
        app:layout_constraintEnd_toEndOf="@+id/commandBtn"
        app:layout_constraintStart_toStartOf="@+id/commandBtn"
        app:layout_constraintTop_toTopOf="@+id/commandBtn" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/barracksBtn"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="160dp"
        android:layout_marginTop="80dp"
        android:alpha="0.3"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text=""
        app:layout_constraintStart_toStartOf="@+id/friendlyShipModel"
        app:layout_constraintTop_toTopOf="@+id/friendlyShipModel"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Circle"
        app:strokeColor="#979797"
        app:strokeWidth="6dp" />

    <TextView
        android:id="@+id/barracksBtnLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Barracks"
        android:textColor="#82AED2FF"
        android:textSize="10sp"
        app:layout_constraintBottom_toBottomOf="@+id/barracksBtn"
        app:layout_constraintEnd_toEndOf="@+id/barracksBtn"
        app:layout_constraintStart_toStartOf="@+id/barracksBtn"
        app:layout_constraintTop_toTopOf="@+id/barracksBtn" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/turretBtn"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="116dp"
        android:layout_marginTop="80dp"
        android:alpha="0.3"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text=""
        app:layout_constraintStart_toStartOf="@+id/friendlyShipModel"
        app:layout_constraintTop_toTopOf="@+id/friendlyShipModel"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Circle"
        app:strokeColor="#979797"
        app:strokeWidth="6dp" />

    <TextView
        android:id="@+id/turretBtnLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Turret"
        android:textColor="#82AED2FF"
        android:textSize="10sp"
        app:layout_constraintBottom_toBottomOf="@+id/turretBtn"
        app:layout_constraintEnd_toEndOf="@+id/turretBtn"
        app:layout_constraintStart_toStartOf="@+id/turretBtn"
        app:layout_constraintTop_toTopOf="@+id/turretBtn" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/medBayBtn"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="280dp"
        android:layout_marginTop="160dp"
        android:alpha="0.3"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text=""
        app:layout_constraintStart_toStartOf="@+id/friendlyShipModel"
        app:layout_constraintTop_toTopOf="@+id/friendlyShipModel"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Circle"
        app:strokeColor="#979797"
        app:strokeWidth="6dp" />

    <TextView
        android:id="@+id/medBayBtnLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Med bay"
        android:textColor="#82AED2FF"
        android:textSize="10sp"
        app:layout_constraintBottom_toBottomOf="@+id/medBayBtn"
        app:layout_constraintEnd_toEndOf="@+id/medBayBtn"
        app:layout_constraintStart_toStartOf="@+id/medBayBtn"
        app:layout_constraintTop_toTopOf="@+id/medBayBtn" />

    <Button
        android:id="@+id/button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="25dp"
        android:backgroundTint="#2A4987"
        android:text="Show broken stations"
        android:textColor="#8FB2FA"
        app:cornerRadius="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <FrameLayout
        android:id="@+id/stationDetailContainer"
        android:layout_width="200dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="6dp"
        android:layout_marginBottom="10dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <FrameLayout
        android:id="@+id/brokenStationContainer"
        android:layout_width="230dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="10dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/stationDetailContainer"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />

    <ImageView
        android:id="@+id/moneySymbol"
        android:layout_width="15dp"
        android:layout_height="15dp"
        android:layout_marginTop="7dp"
        android:layout_marginEnd="10dp"
        app:layout_constraintEnd_toStartOf="@+id/shipHpBar"
        app:layout_constraintTop_toBottomOf="@+id/hullStrengthSymbol"
        app:srcCompat="@drawable/money" />

    <TextView
        android:id="@+id/txtViewMoneyNum"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="moneyNum"
        android:textColor="#FFEB3B"
        android:textSize="10sp"
        app:layout_constraintStart_toEndOf="@+id/moneySymbol"
        app:layout_constraintTop_toTopOf="@+id/moneySymbol" />

    <FrameLayout
        android:id="@+id/statisticsContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>