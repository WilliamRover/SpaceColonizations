                android:textColor="#D9BA40"
                android:textColorLink="#E6D634"
                app:layout_constraintStart_toStartOf="@+id/txtViewJob2"
                app:layout_constraintTop_toBottomOf="@+id/txtViewJob2" />

            <TextView
                android:id="@+id/txtViewPoor2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.6"
                android:text="not enough money"
                android:textColor="#FFDDDD"
                android:textSize="10sp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/btnBuy2" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

