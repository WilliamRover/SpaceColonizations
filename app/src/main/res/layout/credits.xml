<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <Button
        android:id="@+id/btnBack"
        android:layout_width="83dp"
        android:layout_height="40dp"
        android:layout_marginStart="40dp"
        android:layout_marginTop="30dp"
        android:text="Back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/cred1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="Thuan Bui: Front end, design"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="@+id/btnBack"
        app:layout_constraintTop_toBottomOf="@+id/btnBack" />

    <TextView
        android:id="@+id/cred2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Umesh Handuge: Back end"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="@+id/cred1"
        app:layout_constraintTop_toBottomOf="@+id/cred1" />

    <TextView
        android:id="@+id/cred3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Aitiwit Noodat: Back end"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="@+id/cred2"
        app:layout_constraintTop_toBottomOf="@+id/cred2" />

    <TextView
        android:id="@+id/cred4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="Cosmic background is from Calamity mod of Terraria"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="@+id/cred3"
        app:layout_constraintTop_toBottomOf="@+id/cred3" />

</androidx.constraintlayout.widget.ConstraintLayout>