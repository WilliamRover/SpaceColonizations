<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPause"
        android:layout_width="75dp"
        android:layout_height="35dp"
        android:layout_marginStart="28dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="#2A4987"
        android:insetLeft="0dp"
        android:insetTop="0dp"
        android:insetRight="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="5dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeColor="#3B63B5"
        app:strokeWidth="2dp" />

    <ImageView
        android:id="@+id/imgPause"
        android:layout_width="30dp"
        android:layout_height="25dp"
        app:layout_constraintBottom_toBottomOf="@+id/btnPause"
        app:layout_constraintEnd_toEndOf="@+id/btnPause"
        app:layout_constraintStart_toStartOf="@+id/btnPause"
        app:layout_constraintTop_toTopOf="@+id/btnPause"
        app:srcCompat="@drawable/pause" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/pauseOverlay"
        android:name="com.example.spacecolonizations.fragments.PauseOverlayFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        tools:layout="@layout/pause_overlay" />

</androidx.constraintlayout.widget.ConstraintLayout>