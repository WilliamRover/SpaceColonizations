<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/backgroundgame"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/backgroundgame_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SpaceColonizations">
        <!-- Menu -->
        <activity
            android:name=".activities.MenuActivity"
            android:exported="true"
            android:screenOrientation="sensorLandscape">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <!-- Credits -->
        <activity
            android:name=".activities.CreditActivity"
            android:exported="false"
            android:screenOrientation="sensorLandscape" />
        <!-- Map -->
        <activity
            android:name=".activities.MapActivity"
            android:exported="false"
            android:screenOrientation="sensorLandscape" />
        <!-- Fight enemy -->
        <activity
            android:name=".activities.FightEnemyActivity"
            android:exported="false"
            android:screenOrientation="sensorLandscape" />
        <!-- Asteroid -->
        <activity
            android:name=".activities.AsteroidActivity"
            android:exported="false"
            android:screenOrientation="sensorLandscape" />
        <!-- Engine failure -->
        <activity
            android:name=".activities.EngineFailureActivity"
            android:exported="false"
            android:screenOrientation="sensorLandscape" />
        <!-- Shop -->
        <activity
            android:name=".activities.ShopActivity"
            android:exported="false"
            android:screenOrientation="sensorLandscape" />


    </application>

</manifest>
